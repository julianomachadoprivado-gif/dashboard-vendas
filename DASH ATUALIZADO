function getCompleteness(sale) {
  let done = 0;
  if (sale.dados && sale.dados.trim()) done++;
  if (sale.pedido && sale.pedido.trim()) done++;
  if (sale.payment) done++;
  return done;
}

function getClientName(dados) {
  if (!dados || !dados.trim()) return null;
  const lines = dados.trim().split('\n');
  const namePrefixes = [
    'nome completo:', 'nome:', 'cliente:', 'name:', 'full name:', 'nomeCompleto:'
  ];
  for (const line of lines) {
    const lower = line.toLowerCase().trim();
    for (const prefix of namePrefixes) {
      if (lower.startsWith(prefix)) {
        const val = line.split(':').slice(1).join(':').trim();
        if (val) return val;
      }
    }
  }
  // fallback: first non-empty line that doesn't look like a label
  for (const line of lines) {
    const t = line.trim();
    if (t && !t.includes(':')) return t.substring(0, 40);
  }
  return lines[0].trim().substring(0, 40) || null;
}

function getPhoneLast4(dados) {
  if (!dados) return null;
  const phonePrefixes = ['nº de celular:', 'celular:', 'telefone:', 'fone:', 'whatsapp:', 'phone:', 'tel:'];
  const lines = dados.split('\n');
  // First try to find a labeled phone line
  for (const line of lines) {
    const lower = line.toLowerCase().trim();
    for (const prefix of phonePrefixes) {
      if (lower.startsWith(prefix)) {
        const val = line.split(':').slice(1).join(':').replace(/\D/g, '');
        if (val.length >= 8) return val.slice(-4);
      }
    }
  }
  // Fallback: any number sequence that looks like a phone
  const matches = dados.match(/[\d\s\-\(\)]{7,}/g);
  if (!matches) return null;
  for (const m of matches) {
    const digits = m.replace(/\D/g, '');
    if (digits.length >= 8) return digits.slice(-4);
  }
  return null;
}

function paymentLabel(sale) {
  if (!sale.payment) return { text: 'Pendente', cls: 'pending' };
  if (sale.payment === 'pix') return { text: 'PIX', cls: 'pix' };
  if (sale.payment === 'dinheiro') return { text: 'Dinheiro', cls: 'dinheiro' };
  if (sale.payment === 'debito') return { text: 'Débito', cls: 'debito' };
  if (sale.payment === 'cartao') {
    const p = sale.parcelas || 1;
    return { text: p === 1 ? 'Cartão 1x' : `Cartão ${p}x`, cls: 'cartao' };
  }
  return { text: 'Pendente', cls: 'pending' };
}

