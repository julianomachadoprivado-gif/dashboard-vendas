    } else {
      payLine = '<span style="color:var(--text-muted);font-style:italic">Pagamento pendente</span>';
    }

    // First name only
    const firstName = name.split(' ')[0];

    // Header line: last4 only (no time)
    const headerDisplay = last4 ? `****${last4}` : '';

    // Title: FirstName · ****XXXX
    const titleLine = last4 ? `${firstName} <span class="card-title-last4">****${last4}</span>` : firstName;

    const card = document.createElement('div');
    card.className = 'sale-card' + (sale.situacao === 'aberto' ? ' em-aberto' : '');
