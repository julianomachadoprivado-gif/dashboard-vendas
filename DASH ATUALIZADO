// ─── TOTALS ───────────────────────────────────────────────────────────
function calcTotals(list) {
  const finalizados = list.filter(s => s.situacao !== 'aberto' && s.payment);
  const somaValor = finalizados.reduce((acc, s) => {
    if (!s.valor) return acc;
    const n = parseFloat(s.valor.replace(',', '.'));
    return acc + (isNaN(n) ? 0 : n);
  }, 0);
  return {
    total:      list.length,
    sm:         list.filter(s => s.canais && s.canais.includes('sm')).length,
    presencial: list.filter(s => s.canais && s.canais.includes('presencial')).length,
    fora:       list.filter(s => s.canais && s.canais.includes('fora')).length,
    valorTotal: somaValor,
  };
}

function fmtValor(v) {
  return v.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function renderTotals(containerId, list) {
  const el = document.getElementById(containerId);
  if (!el) return;
  if (!list.length) { el.innerHTML = ''; return; }
  const t = calcTotals(list);
  el.innerHTML = `
    <div class="total-item">
      <span class="total-label">Total de pedidos:</span>
      <span class="total-value">${t.total}</span>
    </div>
    <div class="total-item">
      <span class="total-label">Santa Maria:</span>
      <span class="total-value">${t.sm}</span>
    </div>
    <div class="total-item">
      <span class="total-label">Presencial:</span>
      <span class="total-value">${t.presencial}</span>
    </div>
    <div class="total-item">
      <span class="total-label">Para Fora:</span>
      <span class="total-value">${t.fora}</span>
    </div>
    ${t.valorTotal > 0 ? `
    <div class="total-item total-item-valor">
      <span class="total-label">Total vendido:</span>
      <span class="total-value total-valor-destaque">R$ ${fmtValor(t.valorTotal)}</span>
    </div>` : ''}
  `;
}

function renderCalTotals(containerId, list) {
  const el = document.getElementById(containerId);
  if (!el) return;
  if (!list.length) { el.innerHTML = ''; return; }
  const t = calcTotals(list);
