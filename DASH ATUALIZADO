  const sale = sales.find(s => s.id === id);
  if (!sale) return;
  editingId = id;
  currentStep = 1;
  selectedPayment = sale.payment || null;
  selectedParcelas = sale.parcelas || null;
  selectedCanais = sale.canais ? [...sale.canais] : [];
  selectedSituacao = sale.situacao || 'finalizado';
  selectedTiny = sale.tiny || 'passar';
  document.getElementById('input-dados').value = sale.dados || '';
  document.getElementById('input-pedido').value = sale.pedido || '';
  document.getElementById('input-obs').value = sale.obs || '';
  document.getElementById('input-valor').value = sale.valor || '';
  clearPaymentSelection();
  clearCanais();
  renderCanais();
  renderSituacao();
  renderTiny();
  if (selectedPayment) {
    selectPayment(selectedPayment, true);
    if (selectedPayment === 'cartao' && selectedParcelas) {
      setTimeout(() => selectParcela(selectedParcelas), 50);
    }
  }
  document.getElementById('modal-num').textContent = `PEDIDO #${String(sale.num).padStart(3,'0')}`;
  document.getElementById('modal-title').textContent = 'EDITAR PEDIDO';
  document.getElementById('btn-delete').style.display = '';
  openModal();
}

function openModal() {
  updateModalStep();
  document.getElementById('modal-overlay').classList.add('open');
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
}

function handleOverlayClick(e) {
  if (e.target === document.getElementById('modal-overlay')) closeModal();
}

function updateModalStep() {
  for (let i = 1; i <= 6; i++) {
    const sc = document.getElementById(`sc${i}`);
    const sl = document.getElementById(`sl${i}`);
    const content = document.getElementById(`step${i}`);
    sc.className = 'step-circle';
    sl.className = 'step-label';
    content.className = 'step-content';
    if (i < currentStep) { sc.classList.add('done'); sl.classList.add('done'); sc.textContent = '✓'; }
    else if (i === currentStep) { sc.classList.add('active'); sl.classList.add('active'); sc.textContent = i; content.classList.add('active'); }
    else { sc.textContent = i; }
  }
  for (let i = 1; i <= 5; i++) {
    document.getElementById(`sline${i}`).className = 'step-line' + (i < currentStep ? ' done' : '');
  }

  const btnBack = document.getElementById('btn-back');
  const btnNext = document.getElementById('btn-next');
  btnBack.style.display = currentStep > 1 ? '' : 'none';
  btnNext.textContent = currentStep === 6 ? '✓ Salvar' : 'Próximo →';
}

function goBack() {
  if (currentStep > 1) { currentStep--; updateModalStep(); }
}

function goNext() {
  if (currentStep < 6) {
    currentStep++;
    updateModalStep();
  } else {
    saveCurrentCard();
  }
}

// ─── PAYMENT ─────────────────────────────────────────────────────────
function clearPaymentSelection() {
  ['pix','dinheiro','cartao','debito'].forEach(p => {
    const el = document.getElementById(`opt-${p}`);
    if (el) el.className = 'pay-option';
  });
  document.getElementById('parcelas-section').classList.remove('visible');
  document.querySelectorAll('.parcela-btn').forEach(b => b.classList.remove('selected'));
}

function selectPayment(type, silent) {
  clearPaymentSelection();
  selectedPayment = type;
  const el = document.getElementById(`opt-${type}`);
  if (el) el.classList.add(`selected-${type}`);
  if (type === 'cartao') {
    buildParcelas();
    document.getElementById('parcelas-section').classList.add('visible');
  }
}

function buildParcelas() {
  const grid = document.getElementById('parcelas-grid');
  grid.innerHTML = '';
  for (let i = 1; i <= 24; i++) {
    const btn = document.createElement('button');
    btn.className = 'parcela-btn' + (selectedParcelas === i ? ' selected' : '');
    btn.textContent = `${i}x`;
    btn.onclick = () => selectParcela(i);
    grid.appendChild(btn);
  }
}

function toggleCanal(canal) {
  const idx = selectedCanais.indexOf(canal);
  if (idx === -1) selectedCanais.push(canal);
  else selectedCanais.splice(idx, 1);
  renderCanais();
}

function renderCanais() {
  ['sm','presencial','fora'].forEach(c => {
    const btn = document.getElementById(`canal-${c}`);
    if (btn) btn.classList.toggle('selected', selectedCanais.includes(c));
  });
}

function clearCanais() {
  selectedCanais = [];
  renderCanais();
}

function selectSituacao(val) {
  selectedSituacao = val;
  ['finalizado','aberto'].forEach(v => {
    const el = document.getElementById(`opt-${v}`);
    if (el) el.className = 'situacao-option' + (v === val ? ` selected-${v}` : '');
  });
}

function renderSituacao() {
  selectSituacao(selectedSituacao);
}

function selectTiny(val) {
  selectedTiny = val;
  ['passar','ok'].forEach(v => {
    const el = document.getElementById(`opt-tiny-${v}`);
    if (el) el.className = 'situacao-option' + (v === val ? ` selected-tiny-${v}` : '');
  });
}

function renderTiny() {
  selectTiny(selectedTiny);
}

function formatValorInput(el) {
  // allow only digits and comma/dot
  let raw = el.value.replace(/[^\d,\.]/g, '');
  el.value = raw;
}

function selectParcela(n) {
  selectedParcelas = n;
  document.querySelectorAll('.parcela-btn').forEach((b, idx) => {
    b.classList.toggle('selected', idx + 1 === n);
  });
}

// ─── SAVE / DELETE ────────────────────────────────────────────────────
async function saveCurrentCard() {
  const dados = document.getElementById('input-dados').value;
  const pedido = document.getElementById('input-pedido').value;
  const obs = document.getElementById('input-obs').value;
  const valor = document.getElementById('input-valor').value.trim();

  const now = new Date();
  const time = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;

  let sale;
  if (editingId) {
    sale = sales.find(s => s.id === editingId);
    if (sale) {
      sale.dados = dados;
      sale.pedido = pedido;
      sale.obs = obs;
      sale.valor = valor;
      sale.payment = selectedPayment;
      sale.parcelas = selectedPayment === 'cartao' ? selectedParcelas : null;
      sale.canais = [...selectedCanais];
      sale.situacao = selectedSituacao;
      sale.tiny = selectedTiny;
    }
  } else {
    const today = todaySales();
    sale = {
      id: Date.now(),
      date: selectedDayKey || todayKey(),
      num: today.length + 1,
      time,
      dados,
      pedido,
      obs,
      valor,
      payment: selectedPayment,
      parcelas: selectedPayment === 'cartao' ? selectedParcelas : null,
      canais: [...selectedCanais],
      situacao: selectedSituacao,
      tiny: selectedTiny,
    };
    sales.push(sale);
  }

  closeModal();
  renderCards();
  showToast('✓', editingId ? 'Pedido atualizado!' : 'Pedido adicionado com sucesso!');
  await saveData(sale);
}

async function deleteCurrentCard() {
  if (!editingId) return;
  if (!confirm('Tem certeza que deseja excluir este pedido?')) return;
  const id = editingId;
  sales = sales.filter(s => s.id !== id);
  const today = todaySales();
  today.forEach((s, i) => s.num = i + 1);
  closeModal();
  renderCards();
  showToast('🗑', 'Pedido excluído.');
  await deleteData(id);
  // update nums in db
  for (const s of today) await saveData(s);
}

// ─── WEEK / MONTH VIEWS ───────────────────────────────────────────────
function getDaysRange(start, end) {
  const days = [];
  const d = new Date(start);
  while (d <= end) {
    const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
    days.push(key);
    d.setDate(d.getDate() + 1);
  }
  return days;
}

function formatDayLabel(key) {
  const [y, m, d] = key.split('-').map(Number);
  const date = new Date(y, m-1, d);
  const days = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  const months = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  return `${days[date.getDay()]}, ${d} ${months[m-1]}`;
}

function renderSummaryGrid(containerId, days) {
  const container = document.getElementById(containerId);
  container.innerHTML = '';
  let hasAny = false;
  days.forEach(day => {
    const daySales = sales.filter(s => s.date === day);
    if (daySales.length === 0) return;
    hasAny = true;
    const card = document.createElement('div');
    card.className = 'summary-card';
    const isToday = day === todayKey();
    card.innerHTML = `
      <div class="summary-day-title">${formatDayLabel(day)} ${isToday ? '· HOJE' : ''}</div>
      <div class="summary-day-count">${daySales.length} pedido${daySales.length !== 1 ? 's' : ''}</div>
      ${daySales.map(s => {
        const name = getClientName(s.dados) || 'Sem nome';
        const pay = paymentLabel(s);
        return `<div class="summary-item">
          <div>
            <div class="summary-client">${name}</div>
            <div class="summary-payment">#${String(s.num).padStart(3,'0')} · ${s.time || '--:--'}</div>
          </div>
          <span class="payment-badge ${pay.cls}">${pay.text}</span>
        </div>`;
      }).join('')}
    `;
    container.appendChild(card);
  });

  if (!hasAny) {
    container.innerHTML = `<div class="empty-state" style="grid-column:1/-1">
      <div class="empty-icon">📭</div>
      <div class="empty-title">Nenhum pedido encontrado</div>
      <div class="empty-sub">Registros aparecerão aqui conforme você adicionar pedidos.</div>
    </div>`;
  }
}

function renderWeek() {
  const now = new Date();
  const mon = new Date(now);
  mon.setDate(now.getDate() - now.getDay() + (now.getDay() === 0 ? -6 : 1));
  mon.setHours(0,0,0,0);
  const sun = new Date(mon);
  sun.setDate(mon.getDate() + 6);
  const days = getDaysRange(mon, sun);
  renderSummaryGrid('semana-grid', days);
  const weekSales = sales.filter(s => days.includes(s.date));
  renderTotals('totals-semana', weekSales);
}

function renderMonth() {
  const now = new Date();
  const start = new Date(now.getFullYear(), now.getMonth(), 1);
  const end = new Date(now.getFullYear(), now.getMonth() + 1, 0);
  const days = getDaysRange(start, end);
  renderSummaryGrid('mes-grid', days);
  const monthSales = sales.filter(s => days.includes(s.date));
  renderTotals('totals-mes', monthSales);
}

// ─── TOAST ────────────────────────────────────────────────────────────
function showToast(icon, msg) {
  const t = document.getElementById('toast');
  document.getElementById('toast-icon').textContent = icon;
  document.getElementById('toast-msg').textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ─── QUICK DELETE (from card button) ─────────────────────────────────
async function quickDelete(id) {
  if (!confirm('Tem certeza que deseja excluir este pedido?')) return;
  sales = sales.filter(s => s.id !== id);
  const today = todaySales();
  today.forEach((s, i) => s.num = i + 1);
  renderCards();
  showToast('🗑', 'Pedido excluído.');
  await deleteData(id);
  for (const s of today) await saveData(s);
}

// ─── VIEW MODAL ───────────────────────────────────────────────────────
let viewingId = null;

function switchViewTab(tab) {
  ['dados','pedido','pagamento'].forEach(t => {
    document.getElementById(`vtab-${t}`).classList.toggle('active', t === tab);
    document.getElementById(`vcontent-${t}`).classList.toggle('active', t === tab);
  });
}

function openViewModal(id) {
  const sale = sales.find(s => s.id === id);
  if (!sale) return;
  viewingId = id;

  const name = getClientName(sale.dados) || 'Sem nome informado';
  const done = getCompleteness(sale);
  const completeness = done === 3 ? '✅ Completo' : done === 0 ? '⚠️ Sem informações' : `⏳ ${done}/3 etapas`;

  document.getElementById('view-num').textContent = `PEDIDO #${String(sale.num).padStart(3,'0')}`;
  document.getElementById('view-client-title').textContent = name;
  document.getElementById('view-date-time').textContent = `${sale.date || ''} ${sale.time ? '· ' + sale.time : ''}`.trim();
  document.getElementById('view-completeness').textContent = completeness;

  // status badges on tabs
  document.getElementById('vstatus-dados').textContent    = (sale.dados && sale.dados.trim()) ? '✅' : '⚠️';
  document.getElementById('vstatus-pedido').textContent   = (sale.pedido && sale.pedido.trim()) ? '✅' : '⚠️';
  document.getElementById('vstatus-pagamento').textContent = sale.payment ? '✅' : '⚠️';

  // ── ABA 1: DADOS ──
  const dadosEl = document.getElementById('view-dados');
  if (sale.dados && sale.dados.trim()) {
    dadosEl.textContent = sale.dados.trim();
    dadosEl.classList.remove('empty');
  } else {
    dadosEl.textContent = 'Nenhum dado informado ainda.';
    dadosEl.classList.add('empty');
  }

  // ── ABA 2: PEDIDO ──
  const pedidoEl = document.getElementById('view-pedido');
  if (sale.pedido && sale.pedido.trim()) {
    pedidoEl.textContent = sale.pedido.trim();
    pedidoEl.classList.remove('empty');
  } else {
    pedidoEl.textContent = 'Nenhum pedido informado ainda.';
    pedidoEl.classList.add('empty');
  }

  // canal tags
  const canalMap = {
    sm:         { icon: '📱', label: 'SM' },
    presencial: { icon: '🏪', label: 'Presencial' },
    fora:       { icon: '🚗', label: 'Fora' },
  };
  const tagsEl = document.getElementById('view-canal-tags');
  const canais = sale.canais && sale.canais.length ? sale.canais : [];
  tagsEl.innerHTML = canais.map(c => {
    const m = canalMap[c] || { icon: '•', label: c };
    return `<span class="canal-tag ${c}">${m.icon} ${m.label}</span>`;
  }).join('');
  tagsEl.style.display = canais.length ? 'flex' : 'none';

  // obs
  const obsContainer = document.getElementById('view-obs-block');
  if (sale.obs && sale.obs.trim()) {
    obsContainer.style.display = '';
    document.getElementById('view-obs-text').textContent = sale.obs.trim();
  } else {
    obsContainer.style.display = 'none';
  }

  // ── ABA 3: PAGAMENTO ──
  const payEl = document.getElementById('view-payment-display');

  if (!sale.payment) {
    payEl.innerHTML = `
      <div class="view-pay-pending-block">
        <div class="big-icon">⏳</div>
        <p>Forma de pagamento ainda não foi informada.<br>Clique em <strong>Editar Pedido</strong> para adicionar.</p>
      </div>`;
  } else if (sale.payment === 'pix') {
    payEl.innerHTML = `
      <div class="view-pay-block">
        <div class="view-pay-row">
          <div class="view-pay-big-icon pix">⚡</div>
          <div class="view-pay-info">
            <div class="view-pay-method pix">PIX</div>
            <div class="view-pay-desc">Pagamento instantâneo via PIX</div>
          </div>
          <span class="payment-badge pix" style="font-size:13px;padding:7px 16px">PIX</span>
        </div>
      </div>`;
  } else if (sale.payment === 'dinheiro') {
    payEl.innerHTML = `
      <div class="view-pay-block">
        <div class="view-pay-row">
          <div class="view-pay-big-icon cash">💵</div>
          <div class="view-pay-info">
            <div class="view-pay-method cash">Dinheiro</div>
            <div class="view-pay-desc">Pagamento em espécie</div>
          </div>
          <span class="payment-badge dinheiro" style="font-size:13px;padding:7px 16px">Dinheiro</span>
        </div>
      </div>`;
  } else if (sale.payment === 'cartao') {
    const p = sale.parcelas || 1;
    const chips = Array.from({length: 24}, (_, i) => i + 1)
      .map(n => `<div class="vpc ${n === p ? 'active-chip' : ''}">${n}x</div>`)
      .join('');
    payEl.innerHTML = `
      <div class="view-pay-block">
        <div class="view-pay-row">
          <div class="view-pay-big-icon card">💳</div>
          <div class="view-pay-info">
            <div class="view-pay-method card">Cartão de Crédito</div>
            <div class="view-pay-desc">${p === 1 ? 'À vista — 1x' : `Parcelado em ${p}x`}</div>
          </div>
          <span class="payment-badge cartao" style="font-size:13px;padding:7px 16px">${p === 1 ? 'Cartão 1x' : `Cartão ${p}x`}</span>
        </div>
        <div class="view-parcelas-wrapper">
          <div class="view-parcelas-top">
            <div class="view-parcelas-heading">📊 Parcelas</div>
            <div class="view-parcelas-chosen">${p}x <span>${p === 1 ? 'à vista' : 'vezes'}</span></div>
          </div>
          <div class="view-parcelas-chips">${chips}</div>
        </div>
      </div>`;
  }

  // sempre abre na primeira aba
  switchViewTab('dados');
  document.getElementById('view-overlay').classList.add('open');
}

function closeViewModal() {
  document.getElementById('view-overlay').classList.remove('open');
  viewingId = null;
}

function handleViewOverlayClick(e) {
  if (e.target === document.getElementById('view-overlay')) closeViewModal();
}

function editFromView() {
  const id = viewingId;
  closeViewModal();
  openEditModal(id);
}

