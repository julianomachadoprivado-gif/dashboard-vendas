      <div class="card-footer" style="margin-top:10px">
        <div style="flex:1"></div>
        <div class="progress-dots">
          <div class="dot ${done >= 1 ? 'done' : ''}"></div>
          <div class="dot ${done >= 2 ? 'done' : done === 1 ? 'active' : ''}"></div>
          <div class="dot ${done >= 3 ? 'done' : done === 2 ? 'active' : ''}"></div>
        </div>
      </div>
      <div class="card-actions">
        <button class="card-action-btn view" data-id="${sale.id}" data-action="view">👁 Visualizar</button>
        <button class="card-action-btn edit" data-id="${sale.id}" data-action="edit">✏️ Editar</button>
        <button class="card-action-btn del"  data-id="${sale.id}" data-action="del">🗑 Excluir</button>
      </div>
    `;

    card.addEventListener('click', (e) => {
      const btn = e.target.closest('.card-action-btn');
      if (btn) {
        e.stopPropagation();
        const id = Number(btn.dataset.id);
